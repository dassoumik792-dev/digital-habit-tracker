# ============================================================
# FocusPulse AI — .gitignore
# Full-stack Node.js + Next.js + Supabase + OpenAI
# ============================================================


# ─── ENVIRONMENT VARIABLES (NEVER commit these) ──────────────────────────────
# These contain Supabase keys, OpenAI API keys, JWT secrets, DB passwords etc.
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env*.local

# Keep example files — they are safe to commit (no real secrets)
!.env.example
!.env.local.example


# ─── DEPENDENCIES ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ─── BUILD OUTPUTS ───────────────────────────────────────────────────────────
# Next.js
.next/
out/

# Generic build folders
dist/
build/
.output/
.nuxt/
.cache/


# ─── LOGS ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─── RUNTIME & TEMP FILES ────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
.tmp/
tmp/
temp/


# ─── TESTING ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/


# ─── OS / SYSTEM FILES ───────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ─── EDITOR & IDE ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo


# ─── PACKAGE MANAGER LOCKS (keep only one) ───────────────────────────────────
# Uncomment the lock file you are NOT using to ignore it.
# If you use npm  → keep package-lock.json, ignore yarn.lock & pnpm-lock.yaml
# If you use yarn → keep yarn.lock, ignore package-lock.json & pnpm-lock.yaml
# yarn.lock
# pnpm-lock.yaml


# ─── NEXT.JS SPECIFIC ────────────────────────────────────────────────────────
.next/
next-env.d.ts


# ─── SUPABASE LOCAL DEV ──────────────────────────────────────────────────────
# Local Supabase CLI files (if using supabase CLI locally)
.supabase/


# ─── MISC ────────────────────────────────────────────────────────────────────
*.tsbuildinfo
.eslintcache
.stylelintcache
.vercel
.netlify
